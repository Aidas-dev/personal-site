{
  "compilerOptions": {
    "lib": ["ES2021"],
    "target": "ES2021",
    "outDir": "./dist",
    "esModuleInterop": true,
    "declaration": false,
    "moduleResolution": "node16",
    "module": "node16",
    "noImplicitAny": false,
    "strictNullChecks": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", ".medusa", "vitest.config.ts"]
}
